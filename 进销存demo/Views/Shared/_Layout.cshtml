@using System.Security.Claims
@using 进销存demo.Models.Identity
@{
    string Active(string c) => (ViewContext.RouteData.Values["controller"] as string) == c ? "active fw-bold" : "";

    bool IsAuthed = User.Identity?.IsAuthenticated == true;
    string UserName = User.Identity?.Name ?? "";
    string UserRolesLabel = string.Join(" / ",
        User.Claims.Where(c => c.Type == ClaimTypes.Role).Select(c => Roles.Display(c.Value)));
    bool IsAdmin = User.IsInRole(Roles.Admin);
    bool IsPurchaser = User.IsInRole(Roles.Purchaser);
    bool IsSales = User.IsInRole(Roles.Salesperson);
    bool IsWarehouse = User.IsInRole(Roles.Warehouse);
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 进销存demo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/进销存demo.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-primary mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">📦 进销存demo</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between align-items-md-center">
                    <ul class="navbar-nav flex-grow-1">
                        @if (IsAuthed)
                        {
                            <li class="nav-item"><a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index">仪表盘</a></li>
                            <li class="nav-item"><a class="nav-link @Active("Products")" asp-controller="Products" asp-action="Index">商品</a></li>
                            @if (IsAdmin || IsPurchaser)
                            {
                                <li class="nav-item"><a class="nav-link @Active("Suppliers")" asp-controller="Suppliers" asp-action="Index">供应商</a></li>
                                <li class="nav-item"><a class="nav-link @Active("Purchases")" asp-controller="Purchases" asp-action="Index">采购</a></li>
                            }
                            @if (IsAdmin || IsSales)
                            {
                                <li class="nav-item"><a class="nav-link @Active("Customers")" asp-controller="Customers" asp-action="Index">客户</a></li>
                                <li class="nav-item"><a class="nav-link @Active("Sales")" asp-controller="Sales" asp-action="Index">销售</a></li>
                            }
                            <li class="nav-item"><a class="nav-link @Active("Inventory")" asp-controller="Inventory" asp-action="Index">库存</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Inventory" asp-action="Expiring">临期预警</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Inventory" asp-action="Transactions">流水</a></li>
                            <li class="nav-item"><a class="nav-link @Active("Stocktakes")" asp-controller="Stocktakes" asp-action="Index">盘点</a></li>
                            @if (IsAdmin || IsSales)
                            {
                                <li class="nav-item"><a class="nav-link @Active("Receivables")" asp-controller="Receivables" asp-action="Index">应收</a></li>
                            }
                            @if (IsAdmin || IsPurchaser)
                            {
                                <li class="nav-item"><a class="nav-link @Active("Payables")" asp-controller="Payables" asp-action="Index">应付</a></li>
                            }
                        }
                    </ul>
                    @if (IsAuthed)
                    {
                        <form class="d-flex align-items-center me-md-3 my-2 my-md-0 order-md-0" asp-controller="Search" asp-action="Index" method="get" role="search">
                            <input type="search" name="q" class="form-control form-control-sm" placeholder="搜索商品 / 单号" autocomplete="off" style="min-width:11rem;max-width:16rem" />
                        </form>
                    }
                    <ul class="navbar-nav">
                        @if (IsAuthed)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @UserName
                                    @if (!string.IsNullOrEmpty(UserRolesLabel))
                                    {
                                        <span class="badge bg-light text-dark ms-1">@UserRolesLabel</span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">修改密码</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item">注销</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">登录</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid">
        @if (TempData["Msg"] is string msg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @msg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Err"] is string err)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @err
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; @DateTime.Now.Year - 进销存demo · ASP.NET Core 8 · EF Core + SQLite
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @{
        var echartsCdn = "https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js";
    }
    <script src="~/lib/echarts/echarts.min.js" asp-append-version="true"
            onerror="this.onerror=null;this.crossOrigin='anonymous';this.src='@echartsCdn';"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
