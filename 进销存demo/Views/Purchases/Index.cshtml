@model IReadOnlyList<PurchaseOrder>
@using 进销存demo.Models.Identity
@{
    ViewData["Title"] = "采购单";
    var q = ViewBag.Query as PurchaseQuery ?? new PurchaseQuery();
    var suppliers = ViewBag.Suppliers as List<Supplier> ?? new();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h3 class="mb-0">采购单</h3>
    <div class="d-flex flex-wrap gap-2">
        @if (User.IsInRole(Roles.Admin))
        {
            <a class="btn btn-outline-success" asp-action="ExportExcel">导出 Excel</a>
            <a class="btn btn-outline-secondary" asp-action="DownloadImportTemplate">下载导入模板</a>
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#importPurchaseModal">导入 Excel</button>
        }
        <a class="btn btn-primary" asp-action="Create">+ 新建采购单</a>
    </div>
</div>

@if (User.IsInRole(Roles.Admin))
{
    <div class="modal fade" id="importPurchaseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">导入采购草稿 Excel</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">表头与导出一致；相同「单号」多行合并为一张<strong>草稿</strong>单，单号将原样写入（勿与已有单重复）；导入后请在列表中「确认入库」。任一行校验失败则整表回滚。单文件不超过 2MB。</p>
                    <input type="file" name="file" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" class="form-control" required />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">上传导入</button>
                </div>
            </form>
        </div>
    </div>
}

<button class="btn btn-outline-secondary btn-sm d-md-none mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#purchaseFilterCollapse" aria-expanded="false" aria-controls="purchaseFilterCollapse">筛选</button>
<div class="collapse d-md-block mb-3" id="purchaseFilterCollapse">
<form method="get" class="row g-2">
    <div class="col-auto">
        <input type="text" name="keyword" value="@q.Keyword" class="form-control" placeholder="单号" />
    </div>
    <div class="col-auto">
        <select name="supplierId" class="form-select">
            <option value="">全部供应商</option>
            @foreach (var s in suppliers)
            {
                <option value="@s.Id" selected="@(q.SupplierId == s.Id)">@s.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <select name="status" class="form-select">
            <option value="">全部状态</option>
            @foreach (OrderStatus st in Enum.GetValues(typeof(OrderStatus)))
            {
                <option value="@((int)st)" selected="@(q.Status == st)">@st</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <input type="date" name="dateFrom" value="@(q.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" placeholder="起始日期" />
    </div>
    <div class="col-auto">
        <input type="date" name="dateTo" value="@(q.DateTo?.ToString("yyyy-MM-dd"))" class="form-control" placeholder="结束日期" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary">搜索</button>
        <a class="btn btn-outline-secondary" asp-action="Index">重置</a>
    </div>
</form>
</div>

<div class="table-responsive">
<table class="table table-hover table-sm align-middle bg-white jxc-table-wide">
    <thead class="table-light">
        <tr>
            <th>单号</th><th>供应商</th><th>下单日期</th><th>状态</th>
            <th class="text-end">金额</th><th>备注</th><th style="width:140px">操作</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var o in Model)
    {
        var badge = o.Status switch
        {
            OrderStatus.Draft     => "bg-secondary",
            OrderStatus.Confirmed => "bg-success",
            OrderStatus.Cancelled => "bg-dark",
            OrderStatus.Returned  => "bg-warning text-dark",
            _ => "bg-light"
        };
        string statusText = o.Status switch
        {
            OrderStatus.Draft => "草稿",
            OrderStatus.Confirmed => "已入库",
            OrderStatus.Cancelled => "已作废",
            OrderStatus.Returned => "已退货",
            _ => o.Status.ToString()
        };
        <tr>
            <td>@o.OrderNo</td>
            <td>@o.Supplier?.Name</td>
            <td>@o.OrderDate.ToString("yyyy-MM-dd")</td>
            <td><span class="badge @badge">@statusText</span></td>
            <td class="text-end">@o.TotalAmount.ToString("0.00")</td>
            <td>@o.Remark</td>
            <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@o.Id">详情</a></td>
        </tr>
    }
    @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">暂无数据</td></tr> }
    </tbody>
</table>
</div>

@await Html.PartialAsync("_Pager")
