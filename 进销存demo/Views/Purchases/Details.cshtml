@model PurchaseOrder
@{ ViewData["Title"] = "采购单详情"; }

@{
    var badge = Model.Status switch
    {
        OrderStatus.Draft => "bg-secondary",
        OrderStatus.Confirmed => "bg-success",
        OrderStatus.Cancelled => "bg-dark",
        OrderStatus.Returned => "bg-warning text-dark",
        _ => "bg-light"
    };
    string statusText = Model.Status switch
    {
        OrderStatus.Draft => "草稿",
        OrderStatus.Confirmed => "已入库",
        OrderStatus.Cancelled => "已作废",
        OrderStatus.Returned => "已退货",
        _ => Model.Status.ToString()
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 jxc-detail-actions">
    <h3>采购单 @Model.OrderNo <span class="badge @badge ms-2">@statusText</span></h3>
    <div>
        @if (Model.Status == OrderStatus.Draft)
        {
            <form method="post" asp-action="Confirm" asp-route-id="@Model.Id" class="d-inline" onsubmit="return confirm('确认采购入库？库存将增加。')">
                @Html.AntiForgeryToken()
                <button class="btn btn-success">确认入库</button>
            </form>
            <form method="post" asp-action="Cancel" asp-route-id="@Model.Id" class="d-inline" onsubmit="return confirm('确认作废？')">
                @Html.AntiForgeryToken()
                <button class="btn btn-warning">作废</button>
            </form>
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" class="d-inline" onsubmit="return confirm('确认删除？')">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger">删除</button>
            </form>
        }
        @if (Model.Status == OrderStatus.Confirmed)
        {
            <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#returnModal">采购退货</button>
        }
        <a class="btn btn-outline-secondary" asp-action="Print" asp-route-id="@Model.Id" target="_blank" rel="noopener">打印 PDF</a>
        <a class="btn btn-secondary" asp-action="Index">返回</a>
    </div>
</div>

<div class="card card-body mb-3">
    <div class="row">
        <div class="col-md-3"><strong>供应商：</strong>@Model.Supplier?.Name</div>
        <div class="col-md-3"><strong>下单日期：</strong>@Model.OrderDate.ToString("yyyy-MM-dd")</div>
        <div class="col-md-3"><strong>创建时间：</strong>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
        <div class="col-md-3"><strong>合计：</strong>¥ @Model.TotalAmount.ToString("0.00")</div>
        @if (Model.ConfirmedAt.HasValue)
        {
            <div class="col-md-3 mt-2"><strong>确认时间：</strong>@Model.ConfirmedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
        }
        @if (Model.ReturnedAt.HasValue)
        {
            <div class="col-md-3 mt-2"><strong>退货时间：</strong>@Model.ReturnedAt.Value.ToString("yyyy-MM-dd HH:mm")</div>
        }
        <div class="col-md-12 mt-2"><strong>备注：</strong>@Model.Remark</div>
    </div>
</div>

<div class="table-responsive">
<table class="table table-sm bg-white jxc-table-wide">
    <thead class="table-light">
        <tr><th>商品</th><th>生产日期</th><th>批次号</th><th class="text-end">数量</th><th class="text-end">单价</th><th class="text-end">小计</th></tr>
    </thead>
    <tbody>
    @foreach (var i in Model.Items)
    {
        <tr>
            <td>@i.Product?.Code @i.Product?.Name</td>
            <td>@(i.ProductionDate?.ToString("yyyy-MM-dd") ?? "—")</td>
            <td><small>@(string.IsNullOrEmpty(i.BatchNo) ? "—" : i.BatchNo)</small></td>
            <td class="text-end">@i.Quantity @i.Product?.Unit</td>
            <td class="text-end">@i.UnitPrice.ToString("0.00")</td>
            <td class="text-end">@i.Subtotal.ToString("0.00")</td>
        </tr>
    }
    </tbody>
    <tfoot>
        <tr><th colspan="5" class="text-end">合计</th><th class="text-end">@Model.TotalAmount.ToString("0.00")</th></tr>
    </tfoot>
</table>
</div>

@if (Model.Status == OrderStatus.Confirmed)
{
    <div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-action="Return" asp-route-id="@Model.Id" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">采购退货</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>将对此单全部明细进行反向冲减库存，并写入退货流水。</p>
                    <label class="form-label">退货原因 / 备注</label>
                    <input type="text" name="remark" class="form-control" placeholder="可选" maxlength="200" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-warning">确认退货</button>
                </div>
            </form>
        </div>
    </div>
}
