@model PurchaseOrder
@{ ViewData["Title"] = "采购单详情"; }

@{
    var badge = Model.Status switch
    {
        OrderStatus.Draft => "bg-secondary",
        OrderStatus.Confirmed => "bg-success",
        OrderStatus.Cancelled => "bg-dark",
        _ => "bg-light"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>采购单 @Model.OrderNo <span class="badge @badge ms-2">@Model.Status</span></h3>
    <div>
        @if (Model.Status == OrderStatus.Draft)
        {
            <form method="post" asp-action="Confirm" asp-route-id="@Model.Id" class="d-inline" onsubmit="return confirm('确认采购入库？库存将增加。')">
                @Html.AntiForgeryToken()
                <button class="btn btn-success">确认入库</button>
            </form>
            <form method="post" asp-action="Cancel" asp-route-id="@Model.Id" class="d-inline" onsubmit="return confirm('确认作废？')">
                @Html.AntiForgeryToken()
                <button class="btn btn-warning">作废</button>
            </form>
            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" class="d-inline" onsubmit="return confirm('确认删除？')">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger">删除</button>
            </form>
        }
        <a class="btn btn-secondary" asp-action="Index">返回</a>
    </div>
</div>

<div class="card card-body mb-3">
    <div class="row">
        <div class="col-md-3"><strong>供应商：</strong>@Model.Supplier?.Name</div>
        <div class="col-md-3"><strong>下单日期：</strong>@Model.OrderDate.ToString("yyyy-MM-dd")</div>
        <div class="col-md-3"><strong>创建时间：</strong>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
        <div class="col-md-3"><strong>合计：</strong>¥ @Model.TotalAmount.ToString("0.00")</div>
        <div class="col-md-12 mt-2"><strong>备注：</strong>@Model.Remark</div>
    </div>
</div>

<table class="table table-sm bg-white">
    <thead class="table-light">
        <tr><th>商品</th><th class="text-end">数量</th><th class="text-end">单价</th><th class="text-end">小计</th></tr>
    </thead>
    <tbody>
    @foreach (var i in Model.Items)
    {
        <tr>
            <td>@i.Product?.Code @i.Product?.Name</td>
            <td class="text-end">@i.Quantity @i.Product?.Unit</td>
            <td class="text-end">@i.UnitPrice.ToString("0.00")</td>
            <td class="text-end">@i.Subtotal.ToString("0.00")</td>
        </tr>
    }
    </tbody>
    <tfoot>
        <tr><th colspan="3" class="text-end">合计</th><th class="text-end">@Model.TotalAmount.ToString("0.00")</th></tr>
    </tfoot>
</table>
