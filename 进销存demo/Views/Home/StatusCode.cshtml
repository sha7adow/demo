@{
    ViewData["Title"] = $"错误 {ViewBag.Code}";
    var code = (int)(ViewBag.Code ?? 0);
    var (icon, title, desc) = code switch
    {
        404 => ("🔍", "页面不存在", "你访问的地址不存在或已被移除。"),
        401 => ("🔒", "未登录", "请先登录后再访问此页面。"),
        403 => ("🚫", "无权访问", "你当前账号没有权限访问此页面。"),
        500 => ("💥", "服务器错误", "服务器处理请求时发生异常，请稍后重试。"),
        _ => ("⚠️", $"错误 {code}", "请求处理失败。")
    };
}
<div class="container" style="max-width: 640px;">
    <div class="card shadow-sm mt-5">
        <div class="card-body text-center py-5">
            <div style="font-size: 4rem; line-height: 1;">@icon</div>
            <h3 class="mt-3">@title</h3>
            <p class="text-muted">@desc</p>
            <p class="text-muted small">状态码：@code</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">返回首页</a>
        </div>
    </div>
</div>
