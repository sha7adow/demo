@model IEnumerable<Customer>
@{ ViewData["Title"] = "客户"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>客户</h3>
    <a class="btn btn-primary" asp-action="Create">+ 新增客户</a>
</div>

<table class="table table-hover table-sm align-middle bg-white">
    <thead class="table-light">
        <tr><th>名称</th><th>联系人</th><th>电话</th><th>地址</th><th>备注</th><th style="width:160px">操作</th></tr>
    </thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td>@c.Name</td><td>@c.Contact</td><td>@c.Phone</td><td>@c.Address</td><td>@c.Remark</td>
            <td>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id">编辑</a>
                <form method="post" asp-action="Delete" asp-route-id="@c.Id" class="d-inline" onsubmit="return confirm('确认删除？')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">删除</button>
                </form>
            </td>
        </tr>
    }
    @if (!Model.Any()) { <tr><td colspan="6" class="text-center text-muted py-4">暂无数据</td></tr> }
    </tbody>
</table>
