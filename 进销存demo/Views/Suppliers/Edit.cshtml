@model Supplier
@{ ViewData["Title"] = "编辑供应商"; }

<h3>编辑供应商</h3>
<form method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Contact" class="form-label"></label>
            <input asp-for="Contact" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="PaymentTermDays" class="form-label"></label>
            <input asp-for="PaymentTermDays" class="form-control" type="number" min="1" />
        </div>
        <div class="col-12">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Remark" class="form-label"></label>
            <input asp-for="Remark" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">保存</button>
        <a class="btn btn-secondary" asp-action="Index">返回</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
