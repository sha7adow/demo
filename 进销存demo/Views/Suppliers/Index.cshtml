@model IReadOnlyList<Supplier>
@using 进销存demo.Models.Identity
@{
    ViewData["Title"] = "供应商";
    var q = ViewBag.Query as SupplierQuery ?? new SupplierQuery();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h3 class="mb-0">供应商</h3>
    <div class="d-flex flex-wrap gap-2">
        @if (User.IsInRole(Roles.Admin))
        {
            <a class="btn btn-outline-success" asp-action="ExportExcel">导出 Excel</a>
            <a class="btn btn-outline-secondary" asp-action="DownloadImportTemplate">下载导入模板</a>
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#importSupplierModal">导入 Excel</button>
        }
        <a class="btn btn-primary" asp-action="Create">+ 新增供应商</a>
    </div>
</div>

@if (User.IsInRole(Roles.Admin))
{
    <div class="modal fade" id="importSupplierModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">导入供应商 Excel</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">表头须与模板一致；单文件不超过 2MB；名称已存在的行将跳过。</p>
                    <input type="file" name="file" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" class="form-control" required />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">上传导入</button>
                </div>
            </form>
        </div>
    </div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="keyword" value="@q.Keyword" class="form-control" placeholder="名称 / 联系人 / 电话" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary">搜索</button>
        <a class="btn btn-outline-secondary" asp-action="Index">重置</a>
    </div>
</form>

<div class="table-responsive">
<table class="table table-hover table-sm align-middle bg-white jxc-table-wide">
    <thead class="table-light">
        <tr><th>名称</th><th>联系人</th><th>电话</th><th>账期(天)</th><th>地址</th><th>备注</th><th style="width:160px">操作</th></tr>
    </thead>
    <tbody>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.Name</td><td>@s.Contact</td><td>@s.Phone</td><td>@s.PaymentTermDays</td><td>@s.Address</td><td>@s.Remark</td>
            <td>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@s.Id">编辑</a>
                <form method="post" asp-action="Delete" asp-route-id="@s.Id" class="d-inline" onsubmit="return confirm('确认删除？')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">删除</button>
                </form>
            </td>
        </tr>
    }
    @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">暂无数据</td></tr> }
    </tbody>
</table>
</div>

@await Html.PartialAsync("_Pager")
