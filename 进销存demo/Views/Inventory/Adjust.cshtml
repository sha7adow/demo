@{
    ViewData["Title"] = "库存调整";
    var products = ViewBag.Products as List<Product> ?? new();
}

<h3>库存调整</h3>
<p class="text-muted">数量为正表示入库，为负表示出库；本操作会写入流水。</p>

<form method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">商品</label>
            <select name="productId" class="form-select" required>
                <option value="">-- 请选择 --</option>
                @foreach (var p in products)
                {
                    <option value="@p.Id">@p.Code @p.Name（当前库存：@p.Stock @p.Unit）</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">数量变化（可正可负，不能为 0）</label>
            <input name="quantityDelta" type="number" class="form-control" required />
        </div>
        <div class="col-12">
            <label class="form-label">备注</label>
            <input name="remark" class="form-control" placeholder="如：盘点调整 / 报损 / 退货回库..." />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">提交</button>
        <a class="btn btn-secondary" asp-action="Index">返回</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
