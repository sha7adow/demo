@model IEnumerable<Product>
@{ ViewData["Title"] = "商品管理"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>商品管理</h3>
    <a class="btn btn-primary" asp-action="Create">+ 新增商品</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="编码 / 名称" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">搜索</button>
        <a class="btn btn-outline-secondary" asp-action="Index">重置</a>
    </div>
</form>

<table class="table table-hover table-sm align-middle bg-white">
    <thead class="table-light">
        <tr>
            <th>编码</th><th>名称</th><th>单位</th>
            <th class="text-end">采购价</th><th class="text-end">销售价</th>
            <th class="text-end">库存</th><th class="text-end">安全库存</th>
            <th>备注</th><th style="width:160px">操作</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr class="@(p.Stock <= p.SafetyStock ? "table-warning" : "")">
            <td>@p.Code</td>
            <td>@p.Name</td>
            <td>@p.Unit</td>
            <td class="text-end">@p.PurchasePrice.ToString("0.00")</td>
            <td class="text-end">@p.SalePrice.ToString("0.00")</td>
            <td class="text-end">@p.Stock</td>
            <td class="text-end">@p.SafetyStock</td>
            <td>@p.Remark</td>
            <td>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">编辑</a>
                <form method="post" asp-action="Delete" asp-route-id="@p.Id" class="d-inline" onsubmit="return confirm('确认删除？')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">删除</button>
                </form>
            </td>
        </tr>
    }
    @if (!Model.Any())
    {
        <tr><td colspan="9" class="text-center text-muted py-4">暂无数据</td></tr>
    }
    </tbody>
</table>
