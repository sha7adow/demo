@model IReadOnlyList<Product>
@using 进销存demo.Models.Identity
@{
    ViewData["Title"] = "商品管理";
    var q = ViewBag.Query as ProductQuery ?? new ProductQuery();
    var categories = ViewBag.Categories as List<ProductCategory> ?? new();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h3 class="mb-0">商品管理</h3>
    <div class="d-flex flex-wrap gap-2">
        @if (User.IsInRole(Roles.Admin))
        {
            <a class="btn btn-outline-success" asp-action="ExportExcel">导出 Excel</a>
            <a class="btn btn-outline-secondary" asp-action="DownloadProductTemplate">下载导入模板</a>
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#importProductModal">导入 Excel</button>
        }
        @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Warehouse))
        {
            <span class="text-muted small align-self-center d-none d-md-inline">启用批次的商品可在列表中打开「批次」</span>
        }
        <a class="btn btn-primary" asp-action="Create">+ 新增商品</a>
    </div>
</div>

@if (User.IsInRole(Roles.Admin))
{
    <div class="modal fade" id="importProductModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data" class="modal-content">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">导入商品 Excel</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">请先下载模板填写；单文件不超过 2MB；编码重复的行将跳过。</p>
                    <input type="file" name="file" accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" class="form-control" required />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">上传导入</button>
                </div>
            </form>
        </div>
    </div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="keyword" value="@q.Keyword" class="form-control" placeholder="编码 / 名称 / 条码" />
    </div>
    <div class="col-auto">
        <select name="categoryId" class="form-select">
            <option value="">全部分类</option>
            @foreach (var c in categories)
            {
                <option value="@c.Id" selected="@(q.CategoryId == c.Id)">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-auto form-check pt-2 ms-2">
        <input class="form-check-input" type="checkbox" name="onlyWarning" value="true" id="cbWarning" @(q.OnlyWarning == true ? "checked" : "") />
        <label class="form-check-label" for="cbWarning">仅看告警</label>
    </div>
    <div class="col-auto form-check pt-2 ms-2">
        <input class="form-check-input" type="checkbox" name="onlyActive" value="true" id="cbActive" @(q.OnlyActive == true ? "checked" : "") />
        <label class="form-check-label" for="cbActive">仅启用</label>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">搜索</button>
        <a class="btn btn-outline-secondary" asp-action="Index">重置</a>
    </div>
</form>

<div class="table-responsive">
<table class="table table-hover table-sm align-middle bg-white jxc-table-wide">
    <thead class="table-light">
        <tr>
            <th>编码</th><th>名称</th><th>条码</th><th>分类</th><th>单位</th>
            <th class="text-end">采购价</th><th class="text-end">销售价</th>
            <th class="text-end">库存</th><th class="text-end">安全库存</th>
            <th>状态</th><th style="width:160px">操作</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr class="@(p.Stock <= p.SafetyStock ? "table-warning" : "") @(!p.IsActive ? "text-muted" : "")">
            <td>@p.Code</td>
            <td>@p.Name</td>
            <td><small class="text-muted">@p.Barcode</small></td>
            <td>@p.Category?.Name</td>
            <td>@p.Unit</td>
            <td class="text-end">@p.PurchasePrice.ToString("0.00")</td>
            <td class="text-end">@p.SalePrice.ToString("0.00")</td>
            <td class="text-end">@p.Stock</td>
            <td class="text-end">@p.SafetyStock</td>
            <td>
                @if (!p.IsActive) { <span class="badge bg-secondary">停用</span> }
                else { <span class="badge bg-success">启用</span> }
            </td>
            <td>
                @if (p.TrackBatch && (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Warehouse)))
                {
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Batches" asp-route-id="@p.Id">批次</a>
                }
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@p.Id">编辑</a>
                <form method="post" asp-action="Delete" asp-route-id="@p.Id" class="d-inline" onsubmit="return confirm('确认删除？（将软删除，可从数据库恢复）')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger">删除</button>
                </form>
            </td>
        </tr>
    }
    @if (!Model.Any())
    {
        <tr><td colspan="11" class="text-center text-muted py-4">暂无数据</td></tr>
    }
    </tbody>
</table>
</div>

@await Html.PartialAsync("_Pager")
