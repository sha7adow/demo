@model Product
@{ ViewData["Title"] = "编辑商品"; }

<h3>编辑商品</h3>
<form method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-3"><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control" /><span asp-validation-for="Code" class="text-danger"></span></div>
        <div class="col-md-5"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
        <div class="col-md-2"><label asp-for="Unit" class="form-label"></label><input asp-for="Unit" class="form-control" /></div>
        <div class="col-md-2"><label asp-for="SafetyStock" class="form-label"></label><input asp-for="SafetyStock" class="form-control" type="number" /></div>
        <div class="col-md-3"><label asp-for="PurchasePrice" class="form-label"></label><input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-3"><label asp-for="SalePrice" class="form-label"></label><input asp-for="SalePrice" class="form-control" type="number" step="0.01" /></div>
        <div class="col-md-3"><label class="form-label">当前库存</label><input value="@Model.Stock" class="form-control" disabled /></div>
        <div class="col-md-12"><label asp-for="Remark" class="form-label"></label><input asp-for="Remark" class="form-control" /></div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">保存</button>
        <a class="btn btn-secondary" asp-action="Index">返回</a>
    </div>
</form>
<div class="text-muted small mt-2">提示：库存只能通过采购入库 / 销售出库 / 库存调整变更，编辑此处不会改变库存。</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
