{
  "ConnectionStrings": {
    "Default": "Data Source=jxc.db"
  },
  "Jxc": {
    "OrderPrefix": {
      "Purchase": "PO",
      "Sale": "SO",
      "Stocktake": "ST"
    },
    "Paging": {
      "DefaultPageSize": 20,
      "MaxPageSize": 100
    },
    "Inventory": {
      "WarningFactor": 1.0
    },
    "Seed": {
      "DefaultPassword": "Jxc@123456"
    },
    "Company": {
      "Name": "进销存演示公司",
      "PdfFontFamily": "Microsoft YaHei"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
